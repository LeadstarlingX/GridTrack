    <PackageVersion Include="Serilog.AspNetCore" Version="9.0.15" />
    <PackageVersion Include="Serilog.Sinks.Seq" Version="9.0.15" />
    <PackageVersion Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.15" />
