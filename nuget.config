<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <!-- Cap concurrent downloads per feed. NuGet's default (unbounded) opens dozens of
         parallel HTTPS connections; throttled/unstable links (university Wi-Fi, proxies)
         drop them mid-stream → "Received an unexpected EOF or 0 bytes". 10 is concurrent
         enough to stay fast but low enough not to trip the link. -->
    <add key="maxHttpRequestsPerSource" value="10" />
  </config>
</configuration>
